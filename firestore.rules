rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'hamze.zakarie@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['user', 'admin'] &&
             data.displayName is string && data.displayName.size() <= 100;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.type in ['ea', 'indicator', 'course'];
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['pending', 'completed', 'failed'] &&
             exists(/databases/$(database)/documents/products/$(data.productId));
    }

    // --- Collections ---

    // Users
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'user';
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().role == existing().role &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    // Products
    match /products/{productId} {
      allow read: if true; // Marketplace is public
      allow create: if isAdmin() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && isValidOrder(incoming()) && isValidId(orderId);
      // Only admins can update orders (e.g. status)
      allow update: if isAdmin() && isValidOrder(incoming());
    }

    // Simple Admin Registry
    match /admins/{adminId} {
      allow read: if isSignedIn();
    }
  }
}
