{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public and private user information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Trade Product",
      "description": "Expert Advisors, Indicators, or Courses",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "type": { "type": "string", "enum": ["ea", "indicator", "course"] },
        "category": { "type": "string" },
        "stats": {
          "type": "object",
          "properties": {
            "winRate": { "type": "number" },
            "monthlyProfit": { "type": "number" }
          }
        },
        "image": { "type": "string" },
        "fileUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "price", "type"]
    },
    "Order": {
      "title": "User Order",
      "description": "Record of a product purchase",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "productId", "amount", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Available EAs, indicators, and courses"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Transaction logs"
    }
  }
}
